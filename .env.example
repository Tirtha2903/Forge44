# =============================================================================
# Forge44 — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is in .gitignore).
# For production, set these in: Vercel Dashboard → Project Settings → Env Vars
# =============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Required. Get your free Gemini API key (no credit card needed) at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Rate Limiting (optional overrides) ───────────────────────────────────────
# Max compile requests per IP per window (default: 5 per 60 seconds)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW=60000
