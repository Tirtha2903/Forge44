# ============================================================
#  FORGE44 — Environment Variables Reference
#
#  SETUP:
#    Local dev:   cp .env.example .env  →  fill in values  →  npx vercel dev
#    Production:  Vercel Dashboard → Project Settings → Environment Variables
#
#  SECURITY:
#    .env is in .gitignore — NEVER commit it.
#    Never hardcode secrets in source code.
#    Never log env var values (the logger.js module enforces this).
# ============================================================


# ── REQUIRED ────────────────────────────────────────────────────────────────

# Google Gemini API key (free tier available, no credit card required).
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── OPTIONAL — Firebase Admin (enables authenticated rate limits) ────────────
#
# Without this: all requests use IP-based rate limiting (anonymous limits).
# With this:    authenticated users (signed in via Firebase) get higher limits.
#
# Setup:
#   1. Firebase Console → Project Settings → Service Accounts
#      → "Generate new private key" → download the JSON
#   2. Base64-encode it:
#        macOS/Linux:  base64 -i service-account.json
#        Windows PS:   [Convert]::ToBase64String([IO.File]::ReadAllBytes('service-account.json'))
#   3. Paste the output here (one long line, no line breaks)
#   4. Delete the JSON file. NEVER commit it.
FIREBASE_SERVICE_ACCOUNT_BASE64=


# ── OPTIONAL — CORS ─────────────────────────────────────────────────────────
#
# Comma-separated list of allowed origins.
# Default: '*' (allow all — acceptable for same-domain Vercel deployments)
# Production recommendation: set to your exact domain(s)
#   ALLOWED_ORIGINS=https://forge44.app,https://www.forge44.app
ALLOWED_ORIGINS=*


# ── OPTIONAL — Rate Limiting ─────────────────────────────────────────────────
#
# Anonymous users (IP-keyed):    5 compilations per minute
# Authenticated users (UID-keyed): 20 compilations per minute
# Window: 60 seconds (sliding window)
#
RATE_LIMIT_ANON_MAX=5
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_WINDOW_MS=60000


# ── OPTIONAL — Compile Limits ────────────────────────────────────────────────
MIN_PROMPT_LENGTH=5
MAX_PROMPT_LENGTH=2000
MAX_BODY_BYTES=10240


# ── OPTIONAL — Timeouts (milliseconds) ──────────────────────────────────────
#
# Pipeline timeout: total time allowed for a full compile (all stages)
# LLM call timeout: time allowed for a single Gemini API call (shorter to
#                   allow the pipeline to attempt a repair pass on timeout)
PIPELINE_TIMEOUT_MS=25000
LLM_CALL_TIMEOUT_MS=20000


# ── OPTIONAL — LLM Provider ─────────────────────────────────────────────────
# gemini-2.0-flash  — current stable free-tier flash model (recommended)
# gemini-2.5-flash  — latest, better reasoning; may require billing
# gemini-1.5-flash  — DEPRECATED, no longer available
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_TOKENS=8192


# ── OPTIONAL — Logging ───────────────────────────────────────────────────────
#
# LOG_LEVEL: 'debug' | 'info' | 'warn' | 'error'
# LOG_REDACT_PROMPTS: true (default) — replace prompt text with [PROMPT:Nchars]
#                     false — log full prompt text (DEV ONLY, NEVER in production)
LOG_LEVEL=info
LOG_REDACT_PROMPTS=true


# ── FOR FUTURE USE ───────────────────────────────────────────────────────────
#
# Add keys here when integrating new services. Never hardcode them in source.
#
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# POSTHOG_API_KEY=
# RESEND_API_KEY=
