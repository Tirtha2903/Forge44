rules_version = '2';

// ============================================================
//  FORGE44 — Firestore Security Rules
//
//  Principles applied:
//    1. DEFAULT DENY — the final match block denies everything
//       not explicitly permitted above it. This means adding a
//       new collection does NOT accidentally grant access.
//    2. USER ISOLATION — every readable/writable document is
//       scoped to the authenticated user's UID. No user can ever
//       read or write another user's documents.
//    3. FIELD VALIDATION — writes are checked against an allowlist
//       of known fields and type constraints to prevent storing
//       unexpected or oversized data.
//    4. IMMUTABLE HISTORY — compile history items cannot be updated
//       after creation (only created or deleted).
//    5. NO CLIENT DELETION of user accounts — account deletion is
//       performed server-side via Firebase Admin SDK only.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────

    // Is the requester signed in with a verified Firebase account?
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // Does the requester's UID match the given userId path segment?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Field validation ────────────────────────────────────────────────

    // Validate a user profile write.
    // Only allow known safe fields; enforce basic type + size constraints.
    function isValidUserProfile(data) {
      let allowed = ['displayName', 'email', 'photoURL', 'plan', 'createdAt', 'lastLoginAt'];
      return data.keys().hasOnly(allowed)
        && (!('email'       in data) || (data.email       is string && data.email.size()       <= 320))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL'    in data) || (data.photoURL    is string && data.photoURL.size()    <= 512))
        && (!('plan'        in data) || data.plan in ['free', 'pro', 'enterprise']);
    }

    // Validate a compile history item write.
    // The userId field must match the authenticated UID (prevents cross-user writes).
    function isValidCompileItem(data, userId) {
      let required = ['userId', 'prompt', 'createdAt'];
      let allowed  = ['userId', 'prompt', 'result', 'createdAt', 'durationMs', 'qualityScore', 'planMode'];
      return data.keys().hasAll(required)
        && data.keys().hasOnly(allowed)
        && data.userId == userId
        && data.prompt is string
        && data.prompt.size() > 0
        && data.prompt.size() <= 2500
        && (!('durationMs'    in data) || data.durationMs    is number)
        && (!('qualityScore'  in data) || data.qualityScore  is number)
        && (!('planMode'      in data) || data.planMode      is bool);
    }

    // ── Default: deny all ────────────────────────────────────────────────
    //
    // This rule must come LAST in the match block. Firestore evaluates rules
    // from most-specific to least-specific, so the specific rules above take
    // precedence. This catch-all ensures any collection we have NOT explicitly
    // defined remains inaccessible from the client SDK.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── User profiles ────────────────────────────────────────────────────
    //
    // Each user has a document at /users/{uid}.
    // Read and write are restricted to the document's owner.
    // Deletion is forbidden from the client SDK; use Firebase Admin SDK
    // (server-side) when processing account deletion requests.
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if false;
    }

    // ── Compile history ──────────────────────────────────────────────────
    //
    // Per-user compile history stored in a subcollection:
    //   /compiles/{uid}/items/{itemId}
    //
    // Rules:
    //   - Read:   owner only (list + get)
    //   - Create: owner only, with field validation (userId must match UID)
    //   - Update: FORBIDDEN — history items are immutable after creation
    //   - Delete: owner only (allows clearing own history)
    match /compiles/{userId}/items/{itemId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && isValidCompileItem(request.resource.data, userId);
      allow update: if false;
      allow delete: if isOwner(userId);
    }

    // ── Admin collection ─────────────────────────────────────────────────
    //
    // Reserved for internal administrative data (feature flags, system config).
    // NEVER accessible from the client SDK — always via Firebase Admin SDK.
    match /admin/{document=**} {
      allow read, write: if false;
    }

  }
}
